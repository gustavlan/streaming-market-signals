{
  "name": "Music Warehouse Dev",
  "image": "mcr.microsoft.com/devcontainers/python:3.12",
  "containerEnv": {
    "DATA_DIR": "data",
    "DUCKDB_PATH": "data/music_warehouse.duckdb",
    "KWORB_PARQUET_GLOB": "data/raw/kworb/*.parquet",
    "MUSICBRAINZ_RAW_DIR": "data/raw/musicbrainz",
    "DBT_PROFILES_DIR": "dbt_project",
    "DBT_TARGET": "ci"
  },
  "postCreateCommand": "pip install uv && uv pip install -e '.[dev]' --system && playwright install --with-deps chromium && cd dbt_project && dbt deps",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-toolsai.jupyter",
        "innoverio.vscode-dbt-power-user",
        "ms-python.black-formatter"
      ]
    }
  }
}